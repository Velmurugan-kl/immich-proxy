# =============================================================================
# stack.env  —  Immich server environment variables
# =============================================================================
# Copy this file to stack.env and fill in your values.
# This file is read by the immich-server service via env_file in docker-compose.yml
# DO NOT commit stack.env to version control (it contains your DB password).
# =============================================================================

# Where uploaded media is stored on the host
UPLOAD_LOCATION=/mnt/your/photo/library

# Where PostgreSQL data is stored on the host
DB_DATA_LOCATION=/mnt/your/postgres/data

# Immich version (leave as "release" to always use latest stable)
IMMICH_VERSION=release

# Database credentials — change DB_PASSWORD to something secure
DB_PASSWORD=changeme
DB_USERNAME=immich
DB_DATABASE_NAME=immich
